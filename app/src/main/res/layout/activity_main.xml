<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1C2E"
    android:padding="24dp">

    <!-- Top bar like Ruter -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BussWidget"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Avganger fra norske holdeplasser"
        android:textColor="#99AABB"
        android:textSize="14sp"
        android:layout_marginBottom="32dp" />

    <!-- Info card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/row_background"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Slik legger du til en widget"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1.  Hold inne på hjemskjermen"
            android:textColor="#CCDDEE"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2.  Trykk på «Widgets»"
            android:textColor="#CCDDEE"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3.  Finn BussWidget og velg størrelse"
            android:textColor="#CCDDEE"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4.  Dra widgeten til skjermen"
            android:textColor="#CCDDEE"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5.  Søk opp holdeplassen og trykk Lagre"
            android:textColor="#CCDDEE"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Widget sizes card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/row_background"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tilgjengelige størrelser"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/badge_background"
                android:text="2×1" android:textColor="#FFFFFF" android:textSize="11sp"
                android:textStyle="bold" android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="  Liten – viser 1 avgang" android:textColor="#CCDDEE"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/badge_background"
                android:text="4×1" android:textColor="#FFFFFF" android:textSize="11sp"
                android:textStyle="bold" android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="  Medium – viser 2 avganger" android:textColor="#CCDDEE"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/badge_background"
                android:text="4×2" android:textColor="#FFFFFF" android:textSize="11sp"
                android:textStyle="bold" android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="  Stor – viser 4 avganger" android:textColor="#CCDDEE"
                android:textSize="13sp"/>
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Data fra Entur · Ruter · AtB · Skyss"
        android:textColor="#44AABB"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="24dp"/>

</LinearLayout>
